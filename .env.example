# ─── Backend (.env at project root) ─────────────────────────────────────────
# Deploy these on Railway / Render as environment variables

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional: GitHub MCP (for code review demo)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_CLIENT_ID=your_github_clientID_here

# Server
PORT=8000
HOST=0.0.0.0

# Database (Neon PostgreSQL)
DATABASE_CONN=postgresql://user:password@host/dbname?sslmode=require

# API Key Encryption (Sub-project 2)
# ENCRYPTION_KEY=<run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">


# ─── Frontend (frontend/.env.local) ──────────────────────────────────────────
# Deploy these on Vercel as environment variables
# Copy this block into frontend/.env.local for local dev

NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=<run: openssl rand -base64 32>
NEXTAUTH_SECRET=<same value as AUTH_SECRET>
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

# FastAPI backend URL — in Vercel set this to your Railway/Render URL
FASTAPI_URL=http://localhost:8000
